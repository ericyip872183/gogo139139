# ── 数据库 ────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=panlei_prod
MYSQL_USER=panlei
MYSQL_PASSWORD=change_me_db_password

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://:change_me_redis_pass@redis:6379
REDIS_PASSWORD=change_me_redis_pass

# ── JWT ───────────────────────────────────────────────
# 生产环境请使用至少64字符的随机字符串
JWT_SECRET=change_me_very_long_random_secret_at_least_64_chars

# ── 阿里云 OSS（文件存储，二期）─────────────────────
# OSS_REGION=oss-cn-hangzhou
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=panlei-files

# ── 应用 ──────────────────────────────────────────────
NODE_ENV=production
PORT=3000
