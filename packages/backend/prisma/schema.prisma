// Prisma Schema — 盼蕾平台
// Sprint 1: tenant / user 基础表
// Sprint 2: organization 组织架构
// Sprint 3-6: question / paper / exam / score 考试体系
// Sprint 7: score_table 评分表体系
// Sprint 8: module 模块授权

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── 多租户 ───────────────────────────────────────────

model Tenant {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(100)     // 机构名称
  code        String   @unique @db.VarChar(50)  // 机构编码
  logo        String?  @db.VarChar(500)
  isActive    Boolean  @default(true)
  expiredAt   DateTime?                         // 授权到期时间
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users               User[]
  organizations       Organization[]
  tenantModules       TenantModule[]
  questionCategories  QuestionCategory[]
  questions           Question[]
  papers              Paper[]
  exams               Exam[]
  scoreTables         ScoreTable[]
  aiImportTasks       AiImportTask[]

  @@map("tenants")
}

// ─── 用户 ─────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN      // 超级管理员（平台方，唯一）
  TENANT_ADMIN     // 机构管理员（每机构唯一）
  CLASS_ADMIN      // 班级管理员（原 CLASS）
  TEACHER          // 教师
  STUDENT          // 学生
}

model User {
  id           String    @id @default(cuid())
  tenantId     String                          // 所属机构
  username     String    @db.VarChar(50)
  password     String    @db.VarChar(255)      // bcrypt hash
  realName     String    @db.VarChar(50)
  role         UserRole  @default(STUDENT)
  studentNo    String?   @db.VarChar(50)       // 学号/准考证号
  phone        String?   @db.VarChar(20)
  email        String?   @db.VarChar(100)
  avatar       String?   @db.VarChar(500)
  isActive     Boolean   @default(true)
  isDeleted    Boolean   @default(false)       // 【新增】软删除标记
  deletedAt    DateTime?                       // 【新增】删除时间
  deletedBy    String?   @db.VarChar(191)      // 【新增】删除人 ID
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  userOrgs  UserOrg[]
  examParticipants ExamParticipant[]
  examAnswers      ExamAnswer[]
  scores           Score[]
  judgeRecords     ScoreRecord[] @relation("JudgeRecords")
  targetRecords    ScoreRecord[] @relation("TargetRecords")
  aiImportTasks    AiImportTask[]

  @@unique([tenantId, username])
  @@index([tenantId])
  @@index([tenantId, isDeleted])
  @@index([deletedAt])
  @@map("users")
}

// ─── 组织架构（Sprint 2）─────────────────────────────

model Organization {
  id        String  @id @default(cuid())
  tenantId  String
  name      String  @db.VarChar(100)
  parentId  String?                     // 父级ID，null为顶级
  level     Int     @default(1)         // 层级 1-4
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id])
  parent   Organization?  @relation("OrgTree", fields: [parentId], references: [id])
  children Organization[] @relation("OrgTree")
  userOrgs UserOrg[]

  @@index([tenantId, parentId])
  @@map("organizations")
}

model UserOrg {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@map("user_orgs")
}

// ─── 题库（Sprint 3）─────────────────────────────────

enum QuestionType {
  SINGLE    // 单选题
  MULTIPLE  // 多选题
  JUDGE     // 判断题
  FILL      // 填空题
}

enum Difficulty {
  EASY    // 易
  MEDIUM  // 中
  HARD    // 难
}

model QuestionCategory {
  id         String   @id @default(cuid())
  tenantId   String
  name       String   @db.VarChar(100)
  parentId   String?
  moduleType String?  @db.VarChar(50)   // 所属模块，null=母本共用
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant     Tenant             @relation(fields: [tenantId], references: [id])
  parent     QuestionCategory?  @relation("CatTree", fields: [parentId], references: [id])
  children   QuestionCategory[] @relation("CatTree")
  questions  Question[]

  @@index([tenantId, parentId])
  @@map("question_categories")
}

model Question {
  id           String       @id @default(cuid())
  tenantId     String
  categoryId   String?
  type         QuestionType
  difficulty   Difficulty   @default(MEDIUM)
  content      String       @db.Text          // 题目内容（支持富文本/HTML）
  explanation  String?      @db.Text          // 解析
  score        Float        @default(1)       // 默认分值（组卷时可覆盖）
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  category        QuestionCategory? @relation(fields: [categoryId], references: [id])
  options         QuestionOption[]
  mediaItems      QuestionMedia[]
  paperQuestions  PaperQuestion[]
  examAnswers     ExamAnswer[]

  @@index([tenantId, type])
  @@index([tenantId, categoryId])
  @@map("questions")
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  label      String   @db.VarChar(10)    // A/B/C/D 或 填空序号
  content    String   @db.Text
  isCorrect  Boolean  @default(false)
  sortOrder  Int      @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("question_options")
}

// 题目媒体资源（图片/视频/音频）
model QuestionMedia {
  id         String   @id @default(cuid())
  questionId String
  type       String   @db.VarChar(20)    // image / video / audio / file
  url        String   @db.VarChar(500)   // OSS 存储地址
  caption    String?  @db.Text            // 媒体说明
  sortOrder  Int      @default(0)
  fileSize   Int?     @default(0)         // 文件大小（字节）
  duration   Int?     @default(0)         // 视频/音频时长（秒）
  createdAt  DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("question_media")
}

// ─── 试卷与考试（Sprint 4-6）─────────────────────────

model Paper {
  id          String   @id @default(cuid())
  tenantId    String
  title       String   @db.VarChar(200)
  description String?  @db.Text
  totalScore  Float    @default(0)
  duration    Int      @default(60)   // 考试时长（分钟）
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  paperQuestions  PaperQuestion[]
  exams           Exam[]

  @@index([tenantId])
  @@map("papers")
}

model PaperQuestion {
  id         String @id @default(cuid())
  paperId    String
  questionId String
  sortOrder  Int    @default(0)
  score      Float? // 覆盖题目默认分值

  paper    Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@unique([paperId, questionId])
  @@index([paperId])
  @@map("paper_questions")
}

enum ExamStatus {
  DRAFT      // 草稿
  PUBLISHED  // 已发布（未开始）
  ONGOING    // 进行中
  ENDED      // 已结束
  CANCELLED  // 已取消
}

model Exam {
  id          String     @id @default(cuid())
  tenantId    String
  paperId     String
  title       String     @db.VarChar(200)
  description String?    @db.Text
  status      ExamStatus @default(DRAFT)
  startAt     DateTime?
  endAt       DateTime?
  duration    Int?       // 覆盖试卷时长
  allowLate   Boolean    @default(false)
  maxSwitch   Int        @default(3)   // 最大允许切屏次数
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenant       Tenant             @relation(fields: [tenantId], references: [id])
  paper        Paper              @relation(fields: [paperId], references: [id])
  participants ExamParticipant[]
  answers      ExamAnswer[]
  scores       Score[]

  @@index([tenantId, status])
  @@map("exams")
}

model ExamParticipant {
  id       String @id @default(cuid())
  examId   String
  userId   String
  hasSubmitted Boolean @default(false)
  submittedAt  DateTime?
  switchCount  Int     @default(0)  // 切屏次数

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([examId, userId])
  @@index([examId])
  @@map("exam_participants")
}

model ExamAnswer {
  id         String   @id @default(cuid())
  examId     String
  userId     String
  questionId String
  answer     String   @db.Text  // JSON格式：单选"A"，多选["A","B"]，判断true/false，填空"..."
  isCorrect  Boolean?
  score      Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  @@unique([examId, userId, questionId])
  @@index([examId, userId])
  @@map("exam_answers")
}

model Score {
  id          String   @id @default(cuid())
  examId      String
  userId      String
  totalScore  Float    @default(0)
  maxScore    Float    @default(0)
  correctRate Float    @default(0)  // 正确率 0-1
  rank        Int?
  comment     String?  @db.Text     // 教师手动评分备注
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([examId, userId])
  @@index([examId])
  @@map("scores")
}

// ─── 评分表（Sprint 7）────────────────────────────────

enum ScoreTableType {
  ADD   // 加分制
  MINUS // 减分制
}

model ScoreTable {
  id          String         @id @default(cuid())
  tenantId    String
  name        String         @db.VarChar(200)
  type        ScoreTableType @default(ADD)
  totalScore  Float          @default(100)
  description String?        @db.Text
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  items       ScoreItem[]
  records     ScoreRecord[]

  @@index([tenantId])
  @@map("score_tables")
}

model ScoreItem {
  id          String  @id @default(cuid())
  tableId     String
  name        String  @db.VarChar(200)
  score       Float   @default(0)
  description String? @db.Text
  sortOrder   Int     @default(0)

  table ScoreTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([tableId])
  @@map("score_items")
}

model ScoreRecord {
  id          String   @id @default(cuid())
  tableId     String
  judgeId     String   // 考官ID
  targetId    String   // 被考评人ID
  totalScore  Float    @default(0)
  itemScores  Json     // { itemId: score, ... }
  note        String?  @db.Text
  isSynced    Boolean  @default(true)  // 离线同步状态
  createdAt   DateTime @default(now())

  table  ScoreTable @relation(fields: [tableId], references: [id])
  judge  User       @relation("JudgeRecords", fields: [judgeId], references: [id])
  target User       @relation("TargetRecords", fields: [targetId], references: [id])

  @@index([tableId])
  @@index([targetId])
  @@map("score_records")
}

// ─── 模块授权（Sprint 8）─────────────────────────────

model Module {
  id          String  @id @default(cuid())
  code        String  @unique @db.VarChar(50)
  name        String  @db.VarChar(100)
  description String? @db.Text
  phase       String? @db.VarChar(10)   // 二期 / 三期
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())

  tenantModules TenantModule[]

  @@map("modules")
}

model TenantModule {
  id        String   @id @default(cuid())
  tenantId  String
  moduleId  String
  expiredAt DateTime?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  module Module @relation(fields: [moduleId], references: [id])

  @@unique([tenantId, moduleId])
  @@map("tenant_modules")
}

// ─── AI 模块（豆包大模型）────────────────────────────────

model AiUsage {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  providerId  String   @db.VarChar(100)
  modelId     String   @db.VarChar(200)
  module      String   @db.VarChar(50)
  action      String   @db.VarChar(50)
  tokensUsed  Int      @default(0)
  inputTokens Int      @default(0)
  outputTokens Int     @default(0)
  cost        Float    @default(0)
  request     String   @db.Text
  response    String?  @db.Text
  duration    Int      @default(0)
  status      String   @default("success") @db.VarChar(20)
  errorMessage String? @db.Text
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([module])
  @@index([providerId])
  @@map("ai_usage")
}

model AiRecharge {
  id          String   @id @default(cuid())
  tenantId    String
  providerId  String   @db.VarChar(100)
  amount      Float
  tokens      Int
  status      String   @default("pending") @db.VarChar(20)
  orderNo     String   @unique @db.VarChar(50)
  payUrl      String?  @db.VarChar(500)
  paidAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([providerId])
  @@index([orderNo])
  @@map("ai_recharge")
}

model AiConfig {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  apiKey      String   @db.VarChar(200)
  apiSecret   String?  @db.VarChar(200)
  endpoint    String   @db.VarChar(200)
  model       String   @default("doubao-lite-4k") @db.VarChar(50)
  maxTokens   Int      @default(2000)
  isEnabled   Boolean  @default(true)
  systemPrompt String? @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ai_config")
}

// ─── AI 大模型配置（多服务商）─────────────────────────────

// AI 服务商（超管管理）
model AiProvider {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(100)
  baseUrl     String   @db.VarChar(300)
  imageEndpoint String? @db.VarChar(300)  // 图片生成 API 端点
  authType    String   @default("Bearer") @db.VarChar(50)
  apiKey      String   @db.VarChar(500)
  apiSecret   String?  @db.VarChar(500)
  supportImageGeneration Boolean @default(false)
  isEnabled   Boolean  @default(false)
  config      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关联
  models      AiModel[]
  quotas      TenantAiQuota[]

  @@map("ai_providers")
}

// AI 模型（全局模型池）
model AiModel {
  id          String   @id @default(cuid())
  providerId  String
  name        String   @db.VarChar(100)
  modelId     String   @db.VarChar(200)
  type        String   @default("chat") @db.VarChar(50)  // chat | image
  isEp        Boolean  @default(false)
  inputPrice  Decimal  @default(0) @db.Decimal(10, 6)
  outputPrice Decimal  @default(0) @db.Decimal(10, 6)
  isEnabled   Boolean  @default(true)
  lastCheckedAt DateTime?  // 最后检测时间
  lastStatus    String?    @db.VarChar(20)  // 'online' | 'offline' | 'error'
  lastError     String? @db.Text  // 错误信息
  createdAt   DateTime @default(now())

  // 关联
  provider    AiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  tenantModels TenantAiModel[]

  @@index([providerId])
  @@index([type])
  @@map("ai_models")
}

// 机构 AI 配额
model TenantAiQuota {
  id              String   @id @default(cuid())
  tenantId        String
  providerId      String
  totalQuota      Int      @default(0)
  usedQuota       Int      @default(0)
  alertThreshold  Int      @default(20)
  isEnabled       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // 关联
  provider        AiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([tenantId, providerId])
  @@index([tenantId])
  @@map("tenant_ai_quotas")
}

// 机构 - 模型配置（超管为每个机构设置）
model TenantAiModel {
  id          String   @id @default(cuid())
  tenantId    String
  providerId  String
  modelId     String
  scene       String   @db.VarChar(50)
  isDefault   Boolean  @default(false)
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())

  // 关联
  model       AiModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([tenantId, providerId, modelId, scene])
  @@index([tenantId, scene])
  @@map("tenant_ai_models")
}

// AI 预警记录
model AiAlert {
  id              String   @id @default(cuid())
  tenantId        String
  providerId      String
  remainingPercent Int
  status          String   @default("pending") @db.VarChar(20)
  notifiedAt      DateTime?
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())

  @@index([tenantId, status])
  @@map("ai_alerts")
}

// ─── AI 导入题库（Sprint 扩展）─────────────────────────────

// AI 导入任务记录
model AiImportTask {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String
  fileType     String   @db.VarChar(50)  // word / pdf / image
  fileName     String   @db.VarChar(200)
  fileUrl      String   @db.VarChar(500)
  model        String   @db.VarChar(100) @default("doubao-seed-2.0-lite")
  status       String   @db.VarChar(20)  @default("pending")  // pending / processing / completed / failed
  progress     Int      @default(0)      // 进度百分比 0-100
  totalCount   Int      @default(0)
  successCount Int      @default(0)
  errorCount   Int      @default(0)
  parsedData   Json?
  errorMessage String?  @db.Text
  createdAt    DateTime @default(now())
  completedAt  DateTime?

  // 关联
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  user         User     @relation(fields: [userId], references: [id])
  items        AiImportItem[]

  @@index([tenantId, userId])
  @@index([status])
  @@map("ai_import_tasks")
}

// AI 导入题目详情（校对用）
model AiImportItem {
  id           String   @id @default(cuid())
  taskId       String
  questionType String   @db.VarChar(20)  // SINGLE / MULTIPLE / JUDGE / FILL
  content      String   @db.Text
  options      Json?    // { label: 'A', content: '...', isCorrect: true/false }[]
  answer       String   @db.VarChar(100)
  explanation  String?  @db.Text
  difficulty   String   @db.VarChar(20)  @default("MEDIUM")
  status       String   @db.VarChar(20)  @default("pending")  // pending / confirmed / skipped / imported
  importedId   String?  @db.VarChar(191)
  errorMessage String?  @db.Text
  createdAt    DateTime @default(now())

  // 关联
  task         AiImportTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, status])
  @@map("ai_import_items")
}

// ─── 超管操作日志（Admin）─────────────────────────────

model AdminOperationLog {
  id         String   @id @default(cuid())
  adminId    String   @db.VarChar(191)
  action     String   @db.VarChar(50)     // CREATE_USER / UPDATE_USER / DELETE_USER / RESET_PASSWORD 等
  targetType String   @db.VarChar(50)     // USER / TENANT / MODULE
  targetId   String   @db.VarChar(191)
  targetName String?  @db.VarChar(200)
  details    Json?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("admin_operation_logs")
}
